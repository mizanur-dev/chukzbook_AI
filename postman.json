{
  "info": {
    "name": "Chukzbook AI - Local API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Public Chat (Anonymous)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Hello, I have a question about publishing.\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/chat/",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "chat", ""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "2. Premium - Set Email (get session_id)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"user@example.com\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/set_email/",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "set_email", ""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var jsonData = {};\ntry { jsonData = pm.response.json(); } catch(e) {}",
              "if (jsonData.session_id) { pm.environment.set('premium_session_id', jsonData.session_id); }",
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "response": []
    },
    {
      "name": "3. Premium - Chat (uses session_id)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"I have a book idea about a fast-paced thriller set in space.\",\n  \"session_id\": \"{{premium_session_id}}\"\n}"
        },
        "url": {
          "raw": "http://127.0.0.1:8000/api/chat/premium/",
          "protocol": "http",
          "host": ["127", "0", "0", "1"],
          "port": "8000",
          "path": ["api", "chat", "premium", ""]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "response": []
    }
  ]
}