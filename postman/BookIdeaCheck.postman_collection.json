{
  "info": {
    "name": "Book Idea Check API",
    "description": "Collection for testing the Book Idea Check endpoint",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Submit Book Idea",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alicia\",\n  \"email\": \"alicia@example.com\",\n  \"author_brief_text\": \"A warm small-town second-chance romance about two childhood friends reunited after ten years...\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/api/book-idea/check/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "book-idea",
            "check"
          ]
        }
      },
      "response": []
    }
  ]
}
